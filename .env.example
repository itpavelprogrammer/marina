BOT_TOKEN=PUT_YOUR_TELEGRAM_BOT_TOKEN_HERE
# Comma-separated list of admin Telegram user IDs
ADMIN_IDS=123456789,987654321

# SQLite file path (relative to project root is OK)
DB_PATH=bot.db

# Telegram parse mode: HTML recommended
PARSE_MODE=HTML

# Optional: delay between questions in seconds (e.g. 0.4)
QUESTION_DELAY_SEC=0.0
